# Gabesi-AIGuardian — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# Qdrant Cloud
QDRANT_URL=https://your-cluster-id.region.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# OpenAI — used for embeddings (text-embedding-3-large)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Google Gemini — used for LLM backbone of the agent
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Google Earth Engine service account (for satellite data tools)
# GEE_SERVICE_ACCOUNT=your_service_account@project.iam.gserviceaccount.com
# GEE_KEY_FILE=path/to/service_account_key.json
OLLAMA_BASE_URL=http://localhost:11434

# Supabase (Community Warnings Map)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_public_key_here

BILAN_EXPERT_COLLECTION=bilan_expert_collection